<% layout("/layouts/boilerplate.ejs"); %>

<!-- Main filter bar -->
<div class="filter-bar">
  <!-- Filters and arrows -->
  <div id="filters-wrapper">
    <div id="filters-container">
      <div id="filters">
        <!-- Individual filter buttons -->
        <div class="filter" role="button" tabindex="0" aria-label="Trending">
          <i class="fa-solid fa-fire" aria-hidden="true"></i>
          <p>Trending</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Room">
          <i class="fa-solid fa-bed" aria-hidden="true"></i>
          <p>Room</p>
        </div>
        <div
          class="filter"
          role="button"
          tabindex="0"
          aria-label="Iconic cities"
        >
          <i class="fa-solid fa-mountain-city" aria-hidden="true"></i>
          <p>Iconic cities</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Surfing">
          <i class="fa-solid fa-cloud-showers-water" aria-hidden="true"></i>
          <p>Surfing</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Castles">
          <i class="fa-solid fa-chess-rook" aria-hidden="true"></i>
          <p>Castles</p>
        </div>
        <div
          class="filter"
          role="button"
          tabindex="0"
          aria-label="Amazing pools"
        >
          <i class="fa-solid fa-person-swimming" aria-hidden="true"></i>
          <p>Amazing pools</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Beach">
          <i class="fa-solid fa-umbrella-beach" aria-hidden="true"></i>
          <p>Beach</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Cabins">
          <i class="fa-solid fa-house-chimney" aria-hidden="true"></i>
          <p>Cabins</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="OMG">
          <i
            class="fa-solid fa-spaghetti-monster-flying"
            aria-hidden="true"
          ></i>
          <p>OMG!</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="LakeFront">
          <i class="fa-solid fa-water" aria-hidden="true"></i>
          <p>LakeFront</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Mountain">
          <i class="fa-solid fa-mountain" aria-hidden="true"></i>
          <p>Mountain</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Camping">
          <i class="fa-solid fa-campground" aria-hidden="true"></i>
          <p>Camping</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Farms">
          <i class="fa-solid fa-cow" aria-hidden="true"></i>
          <p>Farms</p>
        </div>
        <div class="filter" role="button" tabindex="0" aria-label="Arctic">
          <i class="fa-solid fa-snowflake" aria-hidden="true"></i>
          <p>Arctic</p>
        </div>
      </div>

      <!-- Left Scroll Arrow -->
      <div class="scroll-arrow left" onclick="scrollFilters(-200)">
        <i class="fa-solid fa-chevron-left"></i>
      </div>

      <!-- Right Scroll Arrow -->
      <div class="scroll-arrow right" onclick="scrollFilters(200)">
        <i class="fa-solid fa-chevron-right"></i>
      </div>
    </div>
  </div>

  <!-- Tax Toggle -->
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="taxSwitch"
      />
      <label class="form-check-label" for="taxSwitch">Show taxes</label>
    </div>
  </div>
</div>

<!-- Listings -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for(let listing of allListings) { %>
  <a href="/listings/<%= listing._id %>" style="text-decoration: none">
    <div class="card listing-card h-100">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top"
        alt="<%= listing.image.filename %>"
        style="height: 20rem"
      />
      <div class="card-img-overlay"></div>
      <div class="card-body">
        <p class="card-text">
          <%= listing.title %><br />
          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
          <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
        </p>
      </div>
    </div>
  </a>
  <% } %>
</div>
